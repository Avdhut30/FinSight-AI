APP_NAME=FinSight AI
ENVIRONMENT=development
LOG_LEVEL=INFO
DATABASE_URL=sqlite:///./stock_ai.db
CORS_ORIGINS=http://localhost:5173,http://localhost:4173,http://localhost:3000
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.2
OPENAI_MAX_TOKENS=300
OPENAI_TIMEOUT_SECONDS=4
TWELVE_DATA_API_KEY=
ENABLE_TRANSFORMERS_SENTIMENT=false
FINBERT_MODEL_NAME=ProsusAI/finbert
RATE_LIMIT_REQUESTS=30
RATE_LIMIT_WINDOW_SECONDS=60
NEWS_LIMIT=5
NEWS_FETCH_TIMEOUT_SECONDS=1.0
MARKET_DATA_TIMEOUT_SECONDS=4
DEFAULT_WATCHLIST=INFY.NS
